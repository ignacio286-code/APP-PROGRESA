generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL")
}

model Client {
  id                    String    @id @default(cuid())
  name                  String
  website               String?
  industry              String?
  logoUrl               String?
  // WordPress credentials (encrypted in app layer)
  wpUrl                 String?
  wpUsername            String?
  wpAppPassword         String?
  // Meta Business credentials
  metaAppId             String?
  metaAppSecret         String?
  metaAccessToken       String?
  metaAdAccountId       String?
  // Google Ads credentials
  googleClientId        String?
  googleClientSecret    String?
  googleDeveloperToken  String?
  googleRefreshToken    String?
  googleCustomerId      String?
  // Nanobana
  nanobanaApiKey        String?
  isActive              Boolean   @default(false)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  contentAssets         ContentAsset[]
  socialConnections     SocialConnection[]
  analyticsReports      AnalyticsReport[]
  reportSchedules       ReportSchedule[]
}

model ContentAsset {
  id         String      @id @default(cuid())
  client     Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId   String
  type       AssetType
  url        String
  prompt     String?
  metadata   Json?
  createdAt  DateTime    @default(now())
}

model User {
  id         String     @id @default(cuid())
  name       String
  email      String     @unique
  role       Role       @default(MEMBER)
  avatar     String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  campaigns  CampaignMember[]
  tasks      Task[]
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)
  startDate   DateTime
  endDate     DateTime
  budget      Float?
  spent       Float?         @default(0)
  channel     Channel        @default(OTHER)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  members     CampaignMember[]
  tasks       Task[]
  metrics     Metric[]
}

model CampaignMember {
  id         String   @id @default(cuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  campaignId String
  role       String   @default("member")

  @@unique([userId, campaignId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(TODO)
  dueDate     DateTime?
  campaign    Campaign   @relation(fields: [campaignId], references: [id])
  campaignId  String
  assignee    User?      @relation(fields: [assigneeId], references: [id])
  assigneeId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Metric {
  id          String   @id @default(cuid())
  campaign    Campaign @relation(fields: [campaignId], references: [id])
  campaignId  String
  date        DateTime
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  createdAt   DateTime @default(now())
}

enum Role {
  ADMIN
  MANAGER
  MEMBER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum Channel {
  EMAIL
  SOCIAL
  SEO
  PPC
  CONTENT
  OTHER
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum AssetType {
  IMAGE
  VIDEO
  AVATAR_VIDEO
  DOCUMENT
}

// ─── Analytics Models ─────────────────────────────────────────────────────────

model SocialConnection {
  id           String              @id @default(cuid())
  clientId     String
  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform     String              // facebook | instagram | youtube | tiktok | linkedin | google_ads
  accountId    String
  accountName  String
  accessToken  String
  refreshToken String?
  tokenExpiry  DateTime?
  scope        String?
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  snapshots    AnalyticsSnapshot[]

  @@unique([clientId, platform, accountId])
}

model AnalyticsSnapshot {
  id           String           @id @default(cuid())
  connectionId String
  connection   SocialConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  date         DateTime
  metrics      Json
  createdAt    DateTime         @default(now())
}

model AnalyticsReport {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  dateFrom   DateTime
  dateTo     DateTime
  platforms  String[]
  reportData Json
  createdAt  DateTime @default(now())
}

model ReportSchedule {
  id          String   @id @default(cuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name        String
  frequency   String   // weekly | monthly
  dayOfWeek   Int?
  dayOfMonth  Int?
  recipients  String[]
  platforms   String[]
  isActive    Boolean  @default(true)
  lastSentAt  DateTime?
  nextSendAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── CRM Models ───────────────────────────────────────────────────────────────

model CrmLead {
  id              String    @id @default(cuid())
  mondayId        String?   @unique
  name            String
  rut             String?
  website         String?
  contactDate     DateTime?
  contactPerson   String?
  phone           String?
  email           String?
  status          String?
  location        String?
  city            String?
  hasSocialMedia  String?
  workday         String?
  objective       String?
  selectedPlan    String?
  webPlan         String?
  services        String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CrmProposal {
  id              String    @id @default(cuid())
  mondayId        String?   @unique
  folio           String?   @unique
  name            String
  // Client info
  clientRut       String?
  clientAddress   String?
  clientPhone     String?
  clientEmail     String?
  // Dates & status
  status          String    @default("Pendiente")
  issueDate       DateTime  @default(now())
  dueDate         DateTime?
  // Legacy Monday fields
  proposalDate    DateTime?
  followUpDate    DateTime?
  // Agent
  agentName       String?
  agentPhone      String?
  agentEmail      String?
  // Content
  termsConditions String?
  notes           String?
  // Relations
  items           CrmProposalItem[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model CrmProposalItem {
  id          String       @id @default(cuid())
  proposal    CrmProposal  @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  proposalId  String
  serviceId   String?
  service     CrmService?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  name        String
  description String?
  quantity    Int          @default(1)
  unitPrice   Float        @default(0)
  discount    Float        @default(0)
  tax         Float        @default(0)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
}

model CrmService {
  id            String            @id @default(cuid())
  mondayId      String?           @unique
  name          String
  description   String?
  price         Float?
  notes         String?
  proposalItems CrmProposalItem[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
}

model CrmHostingClient {
  id           String    @id @default(cuid())
  mondayId     String?   @unique
  name         String
  phone        String?
  website      String?
  startDate    String?
  statusOp     String?
  statusProg   String?
  statusProc   String?
  tags         String?
  location     String?
  hostingValue Float?
  paid         String?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
